      },
      "appliesTo": {
        "phases": ["build", "edit", "repair"],
        "agentProfiles": []
      },
      "candidates": [
        {
          "modelResourceId": "deepseek-design-balanced",
          "priority": 10,
          "weight": 100
        }
      ],
      "directSelection": {
        "allowedModelResourceIds": ["deepseek-design-balanced"]
      },
      "automaticSwitch": {
        "enabled": false,
        "allowedReasons": [],
