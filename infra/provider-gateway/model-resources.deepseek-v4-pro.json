      },
      "candidates": [
        {
          "modelResourceId": "deepseek-v4-pro",
          "priority": 10,
          "weight": 100
        }
      ],
      "directSelection": {
        "allowedModelResourceIds": ["deepseek-v4-pro"]
      },
      "automaticSwitch": {
        "enabled": false,
        "allowedReasons": [],
