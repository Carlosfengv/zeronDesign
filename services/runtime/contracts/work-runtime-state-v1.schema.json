{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anydesign.dev/contracts/work-runtime-state-v1.schema.json",
  "title": "WorkRuntimeState v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "projectId", "desiredPublication", "desiredReleaseId", "currentReleaseId", "previousReleaseId", "lastSuccessfulReleaseId", "desiredGeneration", "hostSlug", "runtimeProfileId", "currentDeploymentName", "previousDeploymentName", "serviceName", "ingressName", "deploymentUid", "deploymentResourceVersion", "serviceUid", "serviceResourceVersion", "ingressUid", "ingressResourceVersion", "observedGeneration", "status", "lastError", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": "work-runtime-state@1" },
    "projectId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "desiredPublication": { "enum": ["unpublished", "published"] },
    "desiredReleaseId": { "type": ["string", "null"] },
    "currentReleaseId": { "type": ["string", "null"] },
    "previousReleaseId": { "type": ["string", "null"] },
    "lastSuccessfulReleaseId": { "type": ["string", "null"] },
    "desiredGeneration": { "type": "integer", "minimum": 0 },
    "hostSlug": { "type": "string", "pattern": "^w-[0-9a-f]{20}$" },
    "runtimeProfileId": { "type": "string", "minLength": 1 },
    "currentDeploymentName": { "type": ["string", "null"] },
    "previousDeploymentName": { "type": ["string", "null"] },
    "serviceName": { "type": "string", "minLength": 1 },
    "ingressName": { "type": "string", "minLength": 1 },
    "deploymentUid": { "type": ["string", "null"] },
    "deploymentResourceVersion": { "type": ["string", "null"] },
    "serviceUid": { "type": ["string", "null"] },
    "serviceResourceVersion": { "type": ["string", "null"] },
    "ingressUid": { "type": ["string", "null"] },
    "ingressResourceVersion": { "type": ["string", "null"] },
    "observedGeneration": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["unpublished", "publishing", "published", "updating", "unpublishing", "publish_failed", "update_failed", "reconcile_required"] },
    "lastError": { "type": ["string", "null"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
