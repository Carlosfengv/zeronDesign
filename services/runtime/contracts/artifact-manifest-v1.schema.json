{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zerondesign.dev/contracts/artifact-manifest-v1.schema.json",
  "title": "AnyDesign Artifact Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "versionId",
    "candidateManifestHash",
    "templateId",
    "templateVersion",
    "mounts",
    "files"
  ],
  "properties": {
    "schemaVersion": { "const": "artifact-manifest@1" },
    "projectId": { "type": "string", "minLength": 1 },
    "versionId": { "type": "string", "minLength": 1 },
    "candidateManifestHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "templateId": { "type": "string", "minLength": 1 },
    "templateVersion": { "type": "string", "minLength": 1 },
    "artifactRouteManifestPath": {
      "const": ".anydesign-artifact-routes.json"
    },
    "artifactRouteManifestHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "mounts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["urlPrefix", "artifactPath"],
        "properties": {
          "urlPrefix": {
            "type": "string",
            "pattern": "^/(?:[^/?#\\\\]+(?:/[^/?#\\\\]+)*)?$"
          },
          "artifactPath": { "$ref": "#/$defs/relativePathOrRoot" }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "bytes", "sha256", "contentType"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "contentType": {
            "enum": [
              "text/html; charset=utf-8",
              "text/css; charset=utf-8",
              "text/javascript; charset=utf-8",
              "application/json; charset=utf-8",
              "text/plain; charset=utf-8",
              "application/xml; charset=utf-8",
              "image/svg+xml",
              "image/png",
              "image/jpeg",
              "image/webp",
              "image/gif",
              "image/avif",
              "image/x-icon",
              "font/woff",
              "font/woff2",
              "font/ttf",
              "font/otf",
              "application/wasm",
              "application/manifest+json",
              "application/octet-stream"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!(?:\\.anydesign(?:/|$)|\\.well-known/anydesign(?:/|$)))(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+$"
    },
    "relativePathOrRoot": {
      "oneOf": [
        { "const": "" },
        { "$ref": "#/$defs/relativePath" }
      ]
    }
  }
}
