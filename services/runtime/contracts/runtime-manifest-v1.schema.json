{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zerondesign.dev/contracts/runtime-manifest-v1.schema.json",
  "title": "AnyDesign Runtime Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "deliveryRuntime", "containerPort", "health", "resources", "replicas", "state", "network"],
  "properties": {
    "schemaVersion": { "const": "runtime-manifest@1" },
    "deliveryRuntime": { "const": "static_web_v1" },
    "containerPort": { "const": 8080 },
    "health": {
      "const": {
        "path": "/.well-known/anydesign/healthz",
        "initialDelaySeconds": 2,
        "timeoutSeconds": 2
      }
    },
    "resources": {
      "const": {
        "cpuRequest": "25m",
        "memoryRequest": "32Mi",
        "cpuLimit": "250m",
        "memoryLimit": "128Mi"
      }
    },
    "replicas": { "const": { "min": 1, "max": 1 } },
    "state": { "const": { "mode": "stateless" } },
    "network": { "const": { "egressPolicy": "deny_by_default" } }
  }
}
