{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Provider Gateway Model Resource",
  "type": "object",
  "required": ["schemaVersion", "id", "kind", "enabled", "revision", "endpoint", "auth", "physicalModel", "capabilities"],
  "properties": {
    "schemaVersion": { "const": "model-resource@1" },
    "id": { "type": "string" },
    "providerConnectionId": { "type": "string" },
    "kind": { "enum": ["openai_compatible", "fixture"] },
    "enabled": { "type": "boolean" },
    "published": { "type": "boolean", "default": true },
    "revision": { "type": "integer", "minimum": 1 },
    "endpoint": { "type": "object" },
    "auth": { "type": "object", "required": ["type", "secretRef"] },
    "physicalModel": { "type": "string" },
    "capabilities": {
      "type": "object",
      "properties": {
        "toolCalls": { "type": "boolean" },
        "strictToolSchema": { "type": "boolean" },
        "streaming": { "type": "boolean" },
        "vision": { "type": "boolean" },
        "visionInput": { "type": "boolean" },
        "supportedImageMediaTypes": {
          "type": "array",
          "items": { "enum": ["image/png", "image/jpeg", "image/webp"] },
          "uniqueItems": true
        },
        "maxImageBytes": { "type": "integer", "minimum": 0 },
        "maxImageCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "anyOf": [
              { "properties": { "vision": { "const": true } }, "required": ["vision"] },
              { "properties": { "visionInput": { "const": true } }, "required": ["visionInput"] }
            ]
          },
          "then": {
            "required": ["supportedImageMediaTypes", "maxImageBytes", "maxImageCount"],
            "properties": {
              "supportedImageMediaTypes": { "minItems": 1 },
              "maxImageBytes": { "minimum": 1 },
              "maxImageCount": { "minimum": 1 }
            }
          }
        }
      ]
    },
    "defaults": {
      "type": "object",
      "properties": {
        "requestTimeoutMs": { "type": "integer", "minimum": 1 },
        "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 3 },
        "maxConcurrentRequests": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "temperature": { "type": "number" }
      }
    }
  }
}
